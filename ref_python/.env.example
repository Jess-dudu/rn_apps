# ============================================================
# UCSD Recreation Court Booking Bot — Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp web_booking/.env.example web_booking/.env

# ------------------------------------------------------------
# Your UCSD Recreation login credentials (rec.ucsd.edu)
# ------------------------------------------------------------
UCSD_USERNAME=your_email@ucsd.edu
UCSD_PASSWORD=your_password_here

# ------------------------------------------------------------
# Default court name filter (partial match, case-insensitive)
# Applied to --list and booking when --court is not specified.
# Example: show/book only North courts
# ------------------------------------------------------------
DEFAULT_COURT_FILTER=North

# ------------------------------------------------------------
# --wait mode: polling settings
# ------------------------------------------------------------
# How often to check for an available slot (seconds)
POLL_INTERVAL_SEC=5

# How long to keep trying before giving up (minutes)
POLL_DURATION_MIN=5
